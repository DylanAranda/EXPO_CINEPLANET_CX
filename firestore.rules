rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default allow for sandboxed environment server proxy
    match /{document=**} {
      allow read, write: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && (data.role == 'CREATOR' || data.role == 'CREADOR' || data.role == 'ADMINISTRADOR');
    }

    // Since we are moving from a custom JWT in Express to Firebase, 
    // we should ideally migrate auth too. For now, we'll secure rules 
    // assuming Firebase Auth will be used eventually, but since the 
    // server is the one talking to DB, we'll allow the server's 
    // service account (which usually has Admin bypass).
    // However, if the rules are meant for direct client access:

    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /responses/{responseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
      
      match /answers/{answerId} {
        allow read, create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /kpi_configs/{kpiId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /access_logs/{logId} {
      allow create: if true; // Allow logging
      allow read: if isAdmin();
    }
  }
}
